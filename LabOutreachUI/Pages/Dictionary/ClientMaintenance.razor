@page "/dictionary/clients"
@attribute [Authorize(Policy = "EditDictionary")]
@inject DictionaryService DictionaryService
@inject LabBilling.Core.UnitOfWork.IUnitOfWork UnitOfWork
@inject NavigationManager NavigationManager
@implements IDisposable

<PageTitle>Client Maintenance</PageTitle>

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/">Home</a></li>
        <li class="breadcrumb-item active" aria-current="page">Dictionary</li>
        <li class="breadcrumb-item active" aria-current="page">Client Maintenance</li>
    </ol>
</nav>

<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center py-2">
        <h5 class="mb-0">Client Maintenance</h5>
        <button class="btn btn-primary btn-sm" @onclick="AddNewClient">
            <span class="oi oi-plus"></span> New Client
        </button>
    </div>
    <div class="card-body py-2">
        <div class="row g-2 align-items-end mb-2">
            <div class="col-md-9">
                <label for="clientFilter" class="form-label small mb-1">Filter by Name or Mnemonic</label>
                <input id="clientFilter"
                       type="text"
                       class="form-control form-control-sm"
                       placeholder="Type a name (contains) or an exact mnemonic..."
                       value="@filterText"
                       @oninput="OnFilterInput" />
            </div>
            <div class="col-md-3">
                <div class="form-check">
                    <input class="form-check-input"
                           type="checkbox"
                           id="includeDeleted"
                           checked="@includeDeleted"
                           @onchange="OnIncludeDeletedChanged" />
                    <label class="form-check-label small" for="includeDeleted">
                        Include inactive
                    </label>
                </div>
            </div>
        </div>

        @if (errorMessage != null)
        {
            <div class="alert alert-danger alert-sm mt-2 mb-0 py-1">
                <small><span class="oi oi-warning"></span> @errorMessage</small>
            </div>
        }

        @if (isLoading)
        {
            <div class="text-center py-3">
                <div class="spinner-border spinner-border-sm text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <small class="ms-2">Loading clients...</small>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Mnem</th>
                            <th>Name</th>
                            <th>Address</th>
                            <th>City</th>
                            <th>State</th>
                            <th>Zip</th>
                            <th>Facility No</th>
                            <th>Type</th>
                            <th>Bill Method</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var client in FilteredClients)
                        {
                            <tr class="@(client.IsDeleted ? "text-muted table-light" : null)">
                                <td><span class="badge bg-primary">@client.ClientMnem</span></td>
                                <td>@client.Name</td>
                                <td>@client.StreetAddress1</td>
                                <td>@client.City</td>
                                <td>@client.State</td>
                                <td>@client.ZipCode</td>
                                <td>@client.FacilityNo</td>
                                <td>@(client.ClientType?.Description ?? client.Type.ToString())</td>
                                <td>@client.BillMethod</td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-outline-secondary"
                                            title="Edit client"
                                            @onclick="() => EditClient(client.ClientMnem)">
                                        <span class="oi oi-pencil"></span>
                                    </button>
                                </td>
                            </tr>
                        }
                        @if (!FilteredClients.Any())
                        {
                            <tr>
                                <td colspan="10" class="text-center text-muted py-3">
                                    <small>No clients match the current filter.</small>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="text-muted small mt-2">@FilteredClients.Count() client(s) shown.</div>
        }
    </div>
</div>

<style>
    .alert-sm {
        padding: 0.25rem 0.5rem;
        font-size: 0.875rem;
    }

    .table-sm td, .table-sm th {
        padding: 0.3rem 0.5rem;
        font-size: 0.9rem;
    }
</style>

@code {
    private List<LabBilling.Core.Models.Client> allClients = new();
    private string filterText = "";
    private bool includeDeleted = false;
    private bool isLoading = true;
    private string? errorMessage;
    private System.Threading.CancellationTokenSource? _debounceCts;

    // Filter semantics mirror the legacy ClientMaintenanceForm: Name contains (case-insensitive)
    // OR ClientMnem equals exactly (case-insensitive).
    private IEnumerable<LabBilling.Core.Models.Client> FilteredClients =>
        string.IsNullOrWhiteSpace(filterText)
            ? allClients
            : allClients.Where(c =>
                (!string.IsNullOrEmpty(c.Name) && c.Name.Contains(filterText, StringComparison.OrdinalIgnoreCase))
                || string.Equals(c.ClientMnem, filterText, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        await LoadClients();
    }

    private async Task LoadClients()
    {
        try
        {
            isLoading = true;
            errorMessage = null;
            allClients = await DictionaryService.GetAllClientsAsync(UnitOfWork, includeDeleted);
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading clients: {ex.Message}";
            Console.WriteLine(ex.ToString());
        }
        finally
        {
            isLoading = false;
        }
    }

    // Debounce the text filter (~400ms) so large client lists stay responsive, matching the
    // legacy form's debounced search rather than filtering on every keystroke.
    private async Task OnFilterInput(ChangeEventArgs e)
    {
        filterText = e.Value?.ToString() ?? "";

        _debounceCts?.Cancel();
        _debounceCts = new System.Threading.CancellationTokenSource();
        var token = _debounceCts.Token;

        try
        {
            await Task.Delay(400, token);
            await InvokeAsync(StateHasChanged);
        }
        catch (TaskCanceledException)
        {
            // Superseded by a newer keystroke - ignore.
        }
    }

    private async Task OnIncludeDeletedChanged(ChangeEventArgs e)
    {
        includeDeleted = (bool)(e.Value ?? false);
        await LoadClients();
    }

    private void AddNewClient()
    {
        NavigationManager.NavigateTo("dictionary/clients/new");
    }

    private void EditClient(string clientMnem)
    {
        NavigationManager.NavigateTo($"dictionary/clients/{clientMnem}");
    }

    public void Dispose()
    {
        _debounceCts?.Cancel();
        _debounceCts?.Dispose();
    }
}
